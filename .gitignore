# ─────────────────────────────────────────────────────────────────
#  HistoricalWow — files that must never enter source control
# ─────────────────────────────────────────────────────────────────

# OAuth credentials, never commit
project/export/.env
.env
*.env.local

# Real ServiceNow archive — populated at runtime, mounted as a volume
# in the container. Keeping this out of git is non-negotiable; it
# contains incidents, change requests, user PII, audit history, and
# attachment metadata for the source instance.
project/data/
data/

# Run logs (contain real instance hostname + ticket numbers)
project/export/export.log
project/export/*.log
*.log

# Server access log (mounted at /app/logs in the container; contains
# client IPs, reverse-DNS hostnames, and requested URL paths)
logs/

# Salvage backups created during recovery runs
*.ndjson.flat-salvaged
*.ndjson.tmp
*.shard*.ndjson

# macOS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
venv/

# Editor cruft
.idea/
.vscode/
*.swp
*~

# Docker build artifacts (the registry has the canonical builds)
build/
dist/
