# Copy this file to `.env` in the same directory and fill in real values.
# Never commit `.env` — it has credentials.
#
# Usage:
#   cd project/export
#   set -a; source .env; set +a       # exports every var into the shell
#   python3 historicalwow_export.py

# Required ----------------------------------------------------------------

# Your ServiceNow instance hostname. Either form works:
#   "yourcompany.service-now.com"
#   "https://yourcompany.service-now.com"
SN_INSTANCE=

# OAuth application credentials (System OAuth → Application Registry → your app)
SN_CLIENT_ID=
SN_CLIENT_SECRET=

# Service account user (the one with admin + web-service-only)
SN_USERNAME=historicalwow.export
SN_PASSWORD=

# Optional ---------------------------------------------------------------

# Limit to specific tables for a smoke test, e.g.:
#   SN_TABLES=cmn_location
# SN_TABLES=

# Force a full re-export ignoring saved watermarks
# SN_FULL=1

# Skip attachment file bodies entirely
# SN_SKIP_ATTACHMENTS=1

# Tuning knobs (defaults are usually fine)
# SN_PAGE_SIZE=5000
# SN_RETRIES=5
# SN_TIMEOUT=120
# SN_MANIFEST_LABEL=export
